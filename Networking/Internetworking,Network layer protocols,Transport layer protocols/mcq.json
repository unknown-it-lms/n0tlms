      "QuestionText": "<span style=\"color:#555555\">Multiplexing technique that shifts each signal to a different carrier frequency is_______.</span>",
      "Options": [
        {
          "OptionId": "A",
          "OptionText": "<span style=\"color:#555555\">FDM.</span>"
        },
        {
          "OptionId": "B",
          "OptionText": "<span style=\"color:#555555\">TDM.</span>"
        },
        {
          "OptionId": "C",
          "OptionText": "<span style=\"color:#555555\">Both FDM &amp; TDM.</span>"
        },
        {
          "OptionId": "D",
          "OptionText": "<span style=\"color:#555555\">None of the mentioned.</span>"
        }
      ],
      "Status": 0,
      "Remarks": null,
      "SubjectId": 22,
      "UniqueNodeId": 1185,
      "QuestionTypeId": 0,
      "QuestionId": 70990,
      "Explanation": "<span style=\"color:#555555\">FDM is an abbreviation for Frequency Division Multiplexing. This technique is used when the bandwidth of the channel is greater than the combined bandwidth of all the signals which are to be transmitted.</span>",
      "Answer": "A",
