      "Status": 1,
      "Remarks": null,
      "SubjectId": 72,
      "UniqueNodeId": 4278,
      "QuestionTypeId": 0,
      "QuestionId": 83895,
      "Explanation": "<span id=\"explanation83895\">A sorting algorithm is said to be stable if two objects with equal keys appear in the same order in the sorted output as they appear in the unsorted input.<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Whereas a sorting algorithm is said to be unstable if there are two or more objects with equal keys which don\u2019t appear in same order before and after sorting.</span>",
      "Answer": "D",
      "Marks": 0
